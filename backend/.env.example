# Copy to backend/.env and fill in real values before running the server
# Docker Compose stack (backend/docker-compose.yml). Compose reads
# backend/.env automatically — do not commit the real file.

# Grafana admin login. GRAFANA_ADMIN_PASSWORD is required (compose fails
# fast with a clear error if it's unset) — it overrides the admin/admin
# baked into the read-only grafana.ini.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# Deploy-time note: the compose file publishes Grafana on 3030 (all
# interfaces, `3030:3000`). A server deployment should front it with a
# reverse proxy / TLS, or bind the port mapping to loopback
# (e.g. "127.0.0.1:3030:3000"), rather than exposing it directly.
